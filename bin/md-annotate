#!/bin/bash
# Resolve symlinks (npm link creates one at /usr/local/bin/md-annotate)
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
BIN_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
PKG_DIR="$(dirname "$BIN_DIR")"

exec "$PKG_DIR/node_modules/.bin/tsx" "$BIN_DIR/md-annotate.ts" "$@"
