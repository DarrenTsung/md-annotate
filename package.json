{
  "name": "md-annotate",
  "version": "0.1.0",
  "description": "Google Docs-style annotation tool for markdown files with Claude Code integration",
  "type": "module",
  "bin": {
    "md-annotate": "./bin/md-annotate.ts"
  },
  "scripts": {
    "dev": "concurrently --names server,client \"tsx watch bin/md-annotate.ts\" \"vite\"",
    "dev:server": "tsx watch bin/md-annotate.ts",
    "dev:client": "vite",
    "build": "vite build && tsc --noEmit",
    "start": "tsx bin/md-annotate.ts"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "express": "^4.21.2",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "open": "^10.1.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
